				<tr><td>Amyrtaeus</td><td>1</td><td>Amyrteos</td><td>6</td><td>1</td><td>Amurtaios</td><td>6</td></tr>
			</table>
		</div>
		<div class="pt-5">
			<h3 class="text-center">Dynasty 29</h3>
			<table class="mt-3">
				<tr><th>Pharaoh</th><th colspan="3">Africanus</th><th colspan="3">Eusebius</th></tr>
				<tr
					><td>&nbsp;</td><td colspan="3" class="text-center">4 kings of Mendes, 20 years, 4 months</td><td colspan="3" class="text-center"
						>4 kings of Mendes, 21 years, 4 months<sup>1</sup></td
					></tr
				>
				<tr><td>Nepherites I</td><td>1</td><td>Nepherites</td><td>6</td><td>1</td><td>Nepherites</td><td>6</td></tr>
				<tr><td>Achoris</td><td>2</td><td>Akhoris</td><td>13</td><td>2</td><td>Akhoris</td><td>13</td></tr>
				<tr><td>Psammuthis</td><td>3</td><td>Psammouthis</td><td>1</td><td>3</td><td>Psammouthis</td><td>1</td></tr>
				<tr><td>Nepherites II</td><td>4</td><td>Nepherites</td><td>4m</td><td>4</td><td>Nepherites</td><td>4m</td></tr>
				<tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>5</td><td>Mouthis <sup>2</sup></td><td>1</td></tr>
				<tfoot
					><tr
						><td colspan="7"
							><sup>1</sup> Reigns equal the sum of the five listed kings, despite summary mentioning only four, suggesting one was an usurper.<br
							/><sup>2</sup> Armenian Eusebius place Mouthis directly after Psammouthis.</td
						></tr
					></tfoot
				>
			</table>
		</div>
		<div class="pt-5">
			<h3 class="text-center">Dynasty 30</h3>
			<table class="mt-3">
				<tr><th>Pharaoh</th><th colspan="3">Africanus</th><th colspan="3">Eusebius</th></tr>
				<tr
					><td>&nbsp;</td><td colspan="3" class="text-center">3 kings of Sebennytos, 38 years</td><td colspan="3" class="text-center"
						>3 kings of Sebennytos, 20 years</td
					></tr
				>
				<tr><td>Nectanebo I</td><td>1</td><td>Nektanebes</td><td>18</td><td>1</td><td>Nektanebes</td><td>10</td></tr>
				<tr><td>Djedhor Teos I</td><td>2</td><td>Teos</td><td>2</td><td>2</td><td>Teos</td><td>2</td></tr>
				<tr><td>Nectanebo II</td><td>3</td><td>Nektanebus</td><td>18</td><td>3</td><td>Nektanebos</td><td>8</td></tr>
			</table>
		</div>
		<div class="pt-5">
			<h3 class="text-center">Dynasty 31</h3>
			<table class="mt-3">
				<tr><th>Pharaoh</th><th colspan="3">Africanus</th><th colspan="3">Eusebius</th></tr>
				<tr
					><td>&nbsp;</td><td colspan="3" class="text-center">3 Persian kings, 9 years</td><td colspan="3" class="text-center"
						>3 Persian kings, 16 years</td
					></tr
				>
				<tr><td>Artaxerxes III</td><td>1</td><td>Okhos</td><td>2</td><td>1</td><td>Okhos</td><td>6</td></tr>
				<tr><td>Arses</td><td>2</td><td>Arses</td><td>3</td><td>2</td><td>Arses</td><td>4</td></tr>
				<tr><td>Darius III</td><td>3</td><td>Dareios</td><td>4</td><td>3</td><td>Dareios</td><td>6</td></tr>
			</table>
		</div>
		<p class="text-center lead">The lists of Africanus and Eusebius both end with the conquest of Egypt by Alexander the Great.</p>
