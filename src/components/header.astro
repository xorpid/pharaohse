<script></script>

<style>
	:root {
		--header-height: 3rem;
		--nav-popover-default-height: 21rem;
		--nav-popover-max-height: calc(100dvh - var(--header-height));
		--nav-popover-header-height: 2rem;
	}

	header {
		position: sticky;
		top: 0;
		display: flex;
		align-items: center;
		gap: 2rem;
		background: var(--header-bg);
		box-shadow: 3px 3px 3px -1px rgb(74 73 74 / 0.5);
		height: var(--header-height);
		padding: 0 1rem;
		width: 100%;
		z-index: 50;

		h1 {
			color: #5b2c6f;
			margin: 0;
		}
		nav.main-nav > ul {
			display: flex;
			align-items: center;
			gap: calc(var(--spacing) * 1);
			list-style: none;
			margin: 0;
			padding-inline: 0.5rem;

			& > li > button,
			& > li > a[href] {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				border: none;
				background: none;
				cursor: pointer;
				font-size: 1rem;
				font-weight: bold;
				padding: 0.25rem 0.5rem;
				text-decoration: none;
				border-radius: 0.25rem;

				&:focus,
				&:hover {
					background: var(--dim);
					color: var(--tx-inverted);
				}
			}

			& > li:has([popover]:popover-open) > button > svg {
				transform: rotate(180deg);
			}
		}
	}

	header [popover] {
		max-width: 100%;
		border-radius: 0;
		border: none;
		background-color: --alpha(var(--bg) / 0.95);
	}

	/* Curtain animation for popovers */
	header nav.main-nav [popover] {
		border: none;
		box-shadow: 3px 3px 3px -1px rgb(74 73 74 / 0.5);
		margin: 0;
		height: min(var(--nav-popover-default-height), var(--nav-popover-max-height));
		padding: 1.5rem 2rem;
		top: var(--header-height);
		width: 100%;
		opacity: 0;
		transform: scaleY(0);
		transform-origin: top;
		transition:
			transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1),
			opacity 180ms ease;
		overflow-y: auto;
	}

	header nav.main-nav [popover]:popover-open {
		opacity: 1;
		transform: scaleY(1);
	}

	/* Multi-column popover styling */
	header nav.main-nav [popover] > ul.flex {
		display: flex;
		gap: 3rem;
		height: 100%;
	}

	header nav.main-nav [popover] > ul.flex > li > a[href] {
		color: var(--tx);
		font-weight: bold;
		display: block;
		margin-bottom: 0.75rem;
	}

	/* Hamburger button container */
	header label.mobile-menu-btn {
		background: var(--bg);
		padding: 0.375rem;
		border-radius: 0.375rem;
		cursor: pointer;
	}

	/* Static hamburger (no animation) */
	.hamburger {
		display: flex;
		flex-direction: column;
		gap: 5px;
		border: none;
	}
	.hamburger span {
		display: block;
		height: 3px;
		width: 24px;
		background: currentColor;
		border-radius: 9999px;
	}

	/* Static X for close state */
	.close-x {
		display: none;
		font-size: 28px;
		line-height: 1;
		font-weight: 300;
		color: currentColor;
	}

	/* Switch icons instantly when open */
	header:has(#mobile-menu:checked) .hamburger {
		display: none;
	}
	header:has(#mobile-menu:checked) .close-x {
		display: block;
	}

	/* Mobile layout */
	@media screen and (max-width: 760px) {
		header {
			gap: 1rem;
			justify-content: space-between;
			position: relative;
		}

		h1 {
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
			z-index: 10;
		}

		nav.main-nav {
			display: none;
		}

		header:has(#mobile-menu:checked) nav.main-nav {
			display: block;
			position: fixed;
			top: var(--header-height);
			left: 0;
			right: 0;
			bottom: 0;
			background: var(--bg);
			z-index: 40;
			padding: 2rem 1.5rem;
			overflow-y: auto;
		}

		.dark header:has(#mobile-menu:checked) nav.main-nav {
			background: #1e2937;
		}

		header:has(#mobile-menu:checked) nav.main-nav > ul {
			flex-direction: column;
			gap: 2rem;
			align-items: stretch;
		}

		header:has(#mobile-menu:checked) nav.main-nav ul > li > button,
		header:has(#mobile-menu:checked) nav.main-nav ul > li > a[href] {
			font-size: 1.35rem;
			padding: 1rem 0;
			justify-content: space-between;
			width: 100%;
			text-align: left;
		}
	}

	header [popovertarget]::after,
	header [popovertarget]::before {
		content: unset;
		padding-inline: unset;
	}
</style>
