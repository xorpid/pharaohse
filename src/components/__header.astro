---
/* NAV below with all pages to be shown */

import Toggler from "@components/Toggler.astro";

const { pathname } = Astro.url;
const isActive = (path: string) => (pathname.startsWith(path) ? "bg-gray-200 dark:bg-gray-700" : "");
---

