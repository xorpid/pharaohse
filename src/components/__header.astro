		<!-- Theme toggle – fixed to show correct icon -->
		<div class="flex items-center gap-4 ml-auto">
			<button id="theme-toggle" class="p-2 text-[#556270] dark:text-slate-300 hover:bg-zinc-100 dark:hover:bg-slate-700 rounded-xl transition-all">
				<!-- Sun – shown in light mode -->
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="w-6 h-6 sun dark:hidden"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2.25"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
